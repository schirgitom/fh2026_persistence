{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Warning"
      }
    }
  },
  "MeasurementValidation": {
    "FutureToleranceSeconds": 30
  },
  "Jwt": {
    "Issuer": "AquariumMgmt2026",
    "Audience": "AquariumMgmt2026.Client",
    "Key": "ChangeThisToASecureKeyWithAtLeast32Chars!"
  },
  "TenantDatabase": {
    "ConnectionStringTemplate": "Host=localhost;Port=5433;Database=aquarium_{aquariumId};Username=adswe;Password=adswe"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "QueueName": "measurements.ingest",
    "Username": "admin",
    "Password": "admin",
    "ExchangeName": "aquarium.telemetry",
    "RoutingKey": "aquarium.measurements",
    "Durable": true,
    "DeadLetterExchange": "measurements.dlx",
    "DeadLetterQueue": "measurements.dead",
    "PrefetchCount": 50,
    "ReconnectDelaySeconds": 5
  }
}
